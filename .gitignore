# Python virtual environment (recreate with: make dev)
.venv/
__pycache__/
*.pyc

# Packaging / build artifacts
build/
dist/
*.egg-info/
.pytest_cache/

# Local secrets — never commit your API key
.env

# macOS clutter
.DS_Store

# Personal inputs — kept local, not published
examples/my_*.txt

# Generated reports are build artifacts — regenerate with the agent
/reports/*
!/reports/.gitkeep
